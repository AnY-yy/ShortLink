<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>短链接生成器</title>
  <!-- 引入Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- 引入Font Awesome图标 -->
  <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">

  <!-- 自定义Tailwind配置 -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#165DFF',
            secondary: '#6B7280',
            success: '#10B981',
            light: '#F3F4F6'
          },
          fontFamily: {
            inter: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      }
    }
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .form-input-focus {
        @apply focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all;
      }
      .card-shadow {
        @apply shadow-lg shadow-primary/5;
      }
      .btn-disabled {
        @apply opacity-70 cursor-not-allowed pointer-events-none;
      }
    }
  </style>
</head>
<body class="bg-gray-50 font-inter min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-xl">
    <div class="bg-white rounded-2xl card-shadow p-6 md:p-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary/10 mb-4">
          <i class="fa fa-link text-2xl text-primary"></i>
        </div>
        <h1 class="text-[clamp(1.5rem,3vw,2rem)] font-bold text-gray-800">短链接生成器</h1>
        <p class="text-secondary mt-2">快速将长链接转换为简洁的短链接</p>
      </div>

      <form id="shortenForm" class="space-y-5">
        <!-- 长链接输入框 -->
        <div>
          <label for="longurl" class="block text-sm font-medium text-gray-700 mb-1">长链接</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa fa-globe"></i></span>
            <input type="text" id="longurl" name="longurl" placeholder="请输入需要缩短的原始链接" class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 outline-none form-input-focus" required>
          </div>
        </div>

        <!-- 短链接显示框 -->
        <div>
          <label for="shorturl" class="block text-sm font-medium text-gray-700 mb-1">生成的短链接</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa fa-compress"></i></span>
            <input type="text" id="shorturl" name="shorturl" readonly placeholder="生成后将自动显示在这里" class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 bg-gray-50 outline-none form-input-focus cursor-not-allowed">
          </div>
        </div>

        <!-- 自定义短链接 -->
        <div>
          <label for="selfshorturl" class="block text-sm font-medium text-gray-700 mb-1">自定义短链接 <span class="text-xs text-secondary">(可选)</span></label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa fa-edit"></i></span>
            <input type="text" id="selfshorturl" name="selfshorturl" placeholder="自定义后缀，如：my-link" class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 outline-none form-input-focus">
          </div>
        </div>

        <!-- 自定义过期时间 -->
        <div>
          <label for="expiretime" class="block text-sm font-medium text-gray-700 mb-1">自定义过期时间 <span class="text-xs text-secondary">(可选，单位：小时)</span></label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa fa-clock-o"></i></span>
            <input type="text" id="expiretime" name="expiretime" placeholder="输入链接有效时长，默认永久有效" class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 outline-none form-input-focus">
          </div>
        </div>

        <button type="submit" id="submitBtn" class="w-full bg-primary hover:bg-primary/90 text-white font-medium py-3 px-4 rounded-lg transition-colors flex items-center justify-center gap-2">
          <i class="fa fa-magic"></i><span>生成短链接</span>
        </button>
      </form>
    </div>
    <p class="text-center text-sm text-secondary mt-6">© 2025 短链接生成器</p>
  </div>

  <script>
    const form = document.getElementById('shortenForm');
    const submitBtn = document.getElementById('submitBtn');
    const btnText = submitBtn.querySelector('span');
    const btnIcon = submitBtn.querySelector('i');
    const shortUrlInput = document.getElementById('shorturl');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const longUrl = document.getElementById('longurl').value.trim();
      const customSuffix = document.getElementById('selfshorturl').value.trim();
      const expiretime = document.getElementById('expiretime').value.trim();

      submitBtn.classList.add('btn-disabled');
      btnText.textContent = '生成中...';
      btnIcon.className = 'fa fa-spinner fa-spin';
      shortUrlInput.value = '';

      const postData = {
        longurl: longUrl
      };
      if (customSuffix) postData.selfshorturl = customSuffix;
      if (expiretime) postData.expiretime = parseInt(expiretime);

      const response = await fetch('/api/v1/createurl', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(postData)
      });

      const result = await response.json();
      shortUrlInput.value = result.shorturl || '';

      submitBtn.classList.remove('btn-disabled');
      btnText.textContent = '生成短链接';
      btnIcon.className = 'fa fa-magic';
    });
  </script>
</body>
</html>